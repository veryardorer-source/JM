{
  "manifest_version": 3,
  "name": "이미지 전체 다운로드",
  "version": "1.2",
  "description": "현재 페이지의 모든 이미지를 모아서 한 번에 다운로드합니다.",
  "permissions": ["activeTab", "scripting", "downloads"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "이미지 전체 다운로드"
  }
}
